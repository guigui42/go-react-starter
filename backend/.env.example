# Server
PORT=8080
ENVIRONMENT=development
TRUST_PROXY=false

# Database (PostgreSQL)
PGHOST=localhost
PGPORT=5433
PGUSER=postgres
PGPASSWORD=your_password_here
PGDATABASE=starter
PGSSLMODE=disable
PGSCHEMA=public
AUTO_MIGRATE=true

# Authentication
JWT_SECRET=your-secret-key-at-least-32-characters-long
ENCRYPTION_KEY=your-encryption-key-here
SESSION_DURATION=24h

# WebAuthn / Passkeys
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_ORIGIN=http://localhost:5173
WEBAUTHN_RP_NAME=Go React Starter
WEBAUTHN_TIMEOUT=60000

# Admin
ADMIN_EMAILS=admin@example.com

# Email (optional - uses no-op provider if not configured)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_USE_TLS=true
# EMAIL_FROM=noreply@example.com
# EMAIL_FROM_NAME=Go React Starter
# EMAIL_VERIFY_REQUIRED=false
# EMAIL_TEMPLATES_PATH=./templates/emails
# EMAIL_BASE_URL=http://localhost:5173

# OAuth (optional)
# OAUTH_GITHUB_CLIENT_ID=
# OAUTH_GITHUB_CLIENT_SECRET=
# OAUTH_GOOGLE_CLIENT_ID=
# OAUTH_GOOGLE_CLIENT_SECRET=
# OAUTH_CALLBACK_URL=http://localhost:8080
# OAUTH_STATE_DURATION=10m

# Observability (optional)
# OTEL_ENABLED=false
# OTEL_SERVICE_NAME=go-react-starter-api
# PROMETHEUS_ENABLED=false
# OTEL_TRACING_ENABLED=false
# OTEL_LOGS_ENABLED=false

# Logging
LOG_LEVEL=info
