{
  "name": "go-react-starter",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build --mode production",
    "build:check": "tsc -b && vite build",
    "generate:routes": "tsr generate",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "type-check": "tsc --noEmit",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:a11y": "vitest tests/a11y",
    "test:e2e": "npx playwright test",
    "test:e2e:ui": "npx playwright test --ui",
    "test:e2e:install": "npx playwright install",
    "test:e2e:report": "npx playwright show-report"
  },
  "dependencies": {
    "@mantine/core": "^9.1.0",
    "@mantine/dates": "^9.1.0",
    "@mantine/form": "^9.1.0",
    "@mantine/hooks": "^9.1.0",
    "@mantine/notifications": "^9.1.0",
    "@simplewebauthn/browser": "^13.3.0",
    "@tabler/icons-react": "^3.41.1",
    "@tanstack/react-query": "^5.100.5",
    "@tanstack/react-router": "^1.168.24",
    "dayjs": "^1.11.20",
    "framer-motion": "^12.38.0",
    "i18next": "^26.0.8",
    "i18next-browser-languagedetector": "^8.2.1",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-i18next": "^17.0.4",
    "web-vitals": "^5.2.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@tanstack/react-query-devtools": "^5.100.5",
    "@tanstack/router-cli": "^1.166.36",
    "@tanstack/router-plugin": "^1.167.27",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/ui": "^4.1.5",
    "axe-core": "^4.11.3",
    "baseline-browser-mapping": "^2.10.22",
    "eslint": "^9.39.4",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "happy-dom": "^20.9.0",
    "jsdom": "^29.0.2",
    "prettier": "^3.8.3",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.59.0",
    "vite": "^8.0.10",
    "vite-plugin-pwa": "^0.19.8",
    "vitest": "^4.1.5",
    "vitest-axe": "^0.1.0"
  },
  "overrides": {
    "vite-plugin-pwa": {
      "vite": "$vite"
    }
  }
}
