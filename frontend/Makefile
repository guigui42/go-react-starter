.PHONY: dev build preview test test-coverage lint format install type-check

.DEFAULT_GOAL := dev

install:
	npm install

dev:
	npm run dev

build:
	npm run build

preview:
	npm run preview

test:
	npm run test

test-coverage:
	npm run test:coverage

lint:
	npm run lint

format:
	npm run format

type-check:
	npx tsc --noEmit
